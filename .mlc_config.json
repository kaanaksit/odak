{
  "ignorePatterns": [
    {
      "pattern": "^https?://localhost"
    },
    {
      "pattern": "^https?://127\\.0\\.0\\.1"
    },
    {
      "pattern": "^[#\\(]"
    },
    {
      "pattern": "^mailto:"
    },
    {
      "pattern": "^javascript:"
    }
  ],
  "timeout": "20s",
  "retryOn429": true,
  "retryAttempts": 3,
  "userAgent": "Markdown Link Checker/1.0",
  "requestHeaders": [
    {
      "name": "Accept",
      "value": "text/html,application/xhtml+xml,application/xml;q=0.9,*/*;q=0.8"
    }
  ],
  "fallbackRetryDelay": "5s"
}